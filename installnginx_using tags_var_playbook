- hosts: webserver
  vars:
    training_center_name: "Hemanth's Training Center"
    trainer_name: "Hemanth"
    printphonenum: "yes"
    phone_number: "123-456-7890"
  become: true
  tasks:
    - name: Install Nginx
      package:
        name: nginx
        state: present
      tags:
        - install
    - name: Copy index.html
      copy:
        src: index.html
        dest: /usr/share/nginx/html/index.html
      tags:
        - copy
    - name: start Nginx
      service:
        name: nginx
        state: started
      tags:
        - start
